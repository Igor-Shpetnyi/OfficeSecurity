TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Значення нижче відповідають docker-compose.yml (локальна розробка)
# 127.0.0.1, не localhost: на Windows asyncio інколи намагається спершу
# резолвити localhost у ::1 (IPv6) і висить, поки не стайметаутиться
DATABASE_URL=postgresql://office_security:office_security@127.0.0.1:5432/office_security
REDIS_URL=redis://127.0.0.1:6379/0

ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me

# Рівень 3 конвеєра (ADR-0012/0015), app/common/llm.py. Необов'язково —
# без ключа компонування тексту сповіщення й tie-break неоднозначних
# цілей лишаються на детермінованому шаблонному фолбеку (composed_by=
# 'template_stub'), застосунок працює штатно без цього ключа. Google
# Gemini (безкоштовний тариф, aistudio.google.com/apikey) — свідомий
# вибір замість платних провайдерів, поки бюджет = $0 (Уточнення
# ADR-0015, 2026-07-24).
GEMINI_API_KEY=
