TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Значення нижче відповідають docker-compose.yml (локальна розробка)
# 127.0.0.1, не localhost: на Windows asyncio інколи намагається спершу
# резолвити localhost у ::1 (IPv6) і висить, поки не стайметаутиться
DATABASE_URL=postgresql://office_security:office_security@127.0.0.1:5432/office_security
REDIS_URL=redis://127.0.0.1:6379/0

ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me
